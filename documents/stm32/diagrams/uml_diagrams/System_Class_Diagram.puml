@startuml System_Class_Diagram
!theme vibrant
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam class {
    BackgroundColor<<main>> #E3F2FD
    BorderColor<<main>> #1565C0
    BackgroundColor<<uart>> #E8F5E9
    BorderColor<<uart>> #2E7D32
    BackgroundColor<<command>> #FFF9C4
    BorderColor<<command>> #F57F17
    BackgroundColor<<driver>> #E1F5FF
    BorderColor<<driver>> #01579B
    BackgroundColor<<sensor>> #F3E5F5
    BorderColor<<sensor>> #6A1B9A
    BackgroundColor<<data>> #FCE4EC
    BorderColor<<data>> #C2185B
    BackgroundColor<<storage>> #FFF3E0
    BorderColor<<storage>> #E65100
    BackgroundColor<<display>> #E0F2F1
    BorderColor<<display>> #00695C
    BackgroundColor<<enum>> #ECEFF1
    BorderColor<<enum>> #455A64
    BackgroundColor<<struct>> #FFF8E1
    BorderColor<<struct>> #F57C00
    FontSize 12
    FontName Arial
    ArrowColor #424242
    ArrowThickness 1.5
}

title <size:18><b>STM32 Complete System Class Diagram</b></size>\n<size:12><i>Firmware Architecture with Sensor, RTC, SD Card and Display Integration</i></size>

class main <<main>> {
    <b>== HAL Peripherals ==</b>
    +I2C_HandleTypeDef hi2c1
    +SPI_HandleTypeDef hspi1
    +SPI_HandleTypeDef hspi2
    +UART_HandleTypeDef huart1

    <b>== Global Objects ==</b>
    +sht3x_t g_sht3x
    +ds3231_t g_ds3231
    +mqtt_state_t mqtt_current_state

    <b>== State Variables ==</b>
    +uint32_t next_fetch_ms
    +uint32_t periodic_interval_ms
    +bool force_display_update
    -float outT
    -float outRH
    -uint32_t last_fetch_ms

    <b>== Main Functions ==</b>
    +main() : int
    +SystemClock_Config() : void

    <b>== Peripheral Init ==</b>
    -MX_GPIO_Init() : void
    -MX_I2C1_Init() : void
    -MX_SPI1_Init() : void
    -MX_SPI2_Init() : void
    -MX_USART1_UART_Init() : void
}

class UART <<uart>> {
    <b>== Private Members ==</b>
