    +UART_Handle() : void
    +UART_RxCallback(uint8_t) : void

    <b>== Private Methods ==</b>
    -assemble_line() : bool
}

class RingBuffer <<uart>> {
    <b>== Private Members ==</b>
    -uint8_t* buffer
