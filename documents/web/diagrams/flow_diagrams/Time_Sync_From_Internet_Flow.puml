@startuml Time_Sync_From_Internet_Flow
skinparam backgroundColor #FEFEFE
skinparam shadowing false
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F57F17
    FontSize 12
    FontName Arial
    ArrowColor #424242
    ArrowThickness 2
}

title <size:18><b>Time Sync from Internet Flow</b></size>\n<size:12><i>Automatic Time Synchronization</i></size>

start

:User Clicks
Sync from Internet;

:Get Local Browser Time
now = new Date()
timestamp = now.getTime() / 1000;

:Update Time Picker State
timePickerYear
timePickerMonth
timePickerDay
timePickerHour
timePickerMinute
timePickerSecond;

:Render Calendar
Highlight selected date
Update month/year display;

:Render Time Display
Update HH:MM:SS
24-hour format;

:Add UTC+7 Offset
timestampWithOffset
= timestamp + 7*3600;

:Build Command
SET TIME <timestampWithOffset>;

if (MQTT Connected?) then (no)
    :Show Error
    MQTT not connected
    Cannot send SET TIME;
else (yes)
    :Publish to MQTT
    Topic: stm32Command
    QoS: 1;
    
    :Log to Console
    Time synced from internet:
    <datetime> (UTC+7);
endif

:Update Device Clock
deviceClockMs = timestamp*1000
deviceClockSetAtMs = Date.now();

:Start Clock Ticker
Update footer time
every 1 second;

stop

@enduml